rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Custom Auth Bypass for Netlify Deployment
    // Since Firebase Auth cannot be manually configured by the user, we open these collections
    // to allow a custom Firestore-based login system to work from any domain.
    match /usuarios/{document=**} {
      allow read, write: if true;
    }
    match /categorias/{document=**} {
      allow read, write: if true;
    }
    match /regras/{document=**} {
      allow read, write: if true;
    }
    match /faturas/{document=**} {
      allow read, write: if true;
    }
  }
}
